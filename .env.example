# Copy to .env and fill in. .env is gitignored; this template is committed.
#
# Auth for the co-scientist. The default provider is "claude-oauth", which runs
# the system on a Claude subscription using an OAuth token (no metered API key).
# Get a token with:  claude setup-token

ANTHROPIC_AUTH_TOKEN=          # sk-ant-oat... subscription OAuth token
COSCIENTIST_PROVIDER=claude-oauth   # claude-oauth | anthropic | claude-code | codex

# ANTHROPIC_API_KEY=           # only for provider=anthropic (metered, pay-per-token)
# TAVILY_API_KEY=              # optional web search; system runs without it
